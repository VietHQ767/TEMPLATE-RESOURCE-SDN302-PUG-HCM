doctype html
html
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Sign in
    // Bootstrap CSS
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")

    style.
      body {
        font-family: system-ui, Arial;
        margin: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
        background: #f7f7f7;
      }
      

  body
    header 
        h1 Resident 
        div 
            button(type="button", onclick="window.location.href='/views/resident'") Back
            div.container
               .card
                .card-body
                   h5= resident.residentName
                    p= resident.residentDescription
                    p Apartment: #{resident.apartment.apartmentName}
                    p= resident.floor
                    p= resident.yOB
                    p= resident.isOwned ? 'Owned' : 'Rented'
                    button(type="button") Edit
                    button(type="button") Delete

    // Bootstrap JS (optional, for components needing JS)
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
