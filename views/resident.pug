doctype html
html
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Sign in
    // Bootstrap CSS
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")

    style.
      body {
        font-family: system-ui, Arial;
        margin: 0;
        height: 100vh;
        background: #f7f7f7;
      }
      

  body
    header 
        h1 Resident 

        button(type="button", onclick="window.location.href='/auth/signin'") Logout
    
    main
         div 
            button(type="button") Add Resident
            div.container
                .row
                    each resident in residents
                        .col-md-6
                            .card
                                .card-body
                                    h5= resident.residentName
                                    p= resident.residentDescription
                                    p Apartment: #{resident.apartment.apartmentName}
                                    p Floor: #{resident.floor}
                                    p yOB: #{resident.yOB}
                                    p isOwned: #{resident.isOwned ? 'Owned' : 'Rented'}
                                    button(type="button") Edit
                                    button(type="button") Delete
                                    a(href=`/views/resident/${resident._id}`) View Detail
        

    // Bootstrap JS (optional, for components needing JS)
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
