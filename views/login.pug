doctype html
html
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Sign in
    style.
      body{font-family:system-ui,Arial;margin:0;display:flex;align-items:center;justify-content:center;height:100vh;background:#f7f7f7}
      .card{background:#fff;padding:24px;border-radius:12px;box-shadow:0 6px 20px rgba(0,0,0,.08);width:360px}
      .row{margin-bottom:12px}
      label{display:block;margin-bottom:6px;font-weight:600}
      input{width:100%;padding:10px;border:1px solid #ddd;border-radius:8px}
      button{width:100%;padding:10px;border:0;background:#4f46e5;color:#fff;border-radius:8px;font-weight:700;cursor:pointer}
      .error{color:#b91c1c;margin-bottom:10px}
  body
    .card
      h2(style="margin-top:0") Login
      if error
        .error= error
      form(method="post", action="/auth/signin")
        .row
          label Username
          input(name="us", required)
        .row
          label Password
          input(type="password", name="pw", required)
        button(type="submit") Sign in


