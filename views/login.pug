doctype html
html
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Sign in
    // Bootstrap CSS
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")

    style.
      body {
        font-family: system-ui, Arial;
        margin: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
        background: #f7f7f7;
      }
      .card-custom {
        background: #fff;
        padding: 24px;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0, 0, 0, .08);
        width: 360px;
      }
      .error {
        color: #b91c1c;
        margin-bottom: 10px;
      }

  body
    .card.card-custom
      h2.text-center.mb-4 Login
      if error
        .error= error
      form(method="post", action="/auth/login") 
        .mb-3
          label.form-label Username
          input.form-control(name="us", required)
        .mb-3
          label.form-label Password
          input.form-control(type="password", name="pw", required)
        button.btn.btn-primary.w-100(type="submit") Sign in

    // Bootstrap JS (optional, for components needing JS)
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
